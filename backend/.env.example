# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Model per agent (defaults to gpt-4o-mini)
ROUTER_MODEL=gpt-4o-mini
BILLING_MODEL=gpt-4o-mini
ACCOUNT_MODEL=gpt-4o-mini
TECHNICAL_SUPPORT_MODEL=gpt-4o-mini
SHIPPING_MODEL=gpt-4o-mini
FALLBACK_MODEL=gpt-4o-mini
SAFETY_MODEL=gpt-4o-mini

# Routing policy
ROUTING_CONFIDENCE_LOW_THRESHOLD=0.50
MAX_LLM_CALLS=5
MAX_RETRY_COUNT=2

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/inquiry_triage

# Security
RATE_LIMIT=20/minute
DAILY_LIMIT=10

# LangSmith
LANGSMITH_API_KEY=ls__...
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=inquiry-triage-eval

# MCP 서버 설정 (선택적 — 미설정 시 MCP 비활성화, 기존 동작 유지)
# MCP_BILLING_URL=http://localhost:8001/mcp
# MCP_ACCOUNT_URL=http://localhost:8002/mcp
# MCP_SHIPPING_URL=http://localhost:8003/mcp
# MCP_TECHNICAL_SUPPORT_URL=http://localhost:8004/mcp
# MCP_CONNECT_TIMEOUT=5.0
# MCP_TOOL_TIMEOUT=10.0

# v3 MCP 서버 (FAQSearch + SlackNotify)
# 로컬 실행:
#   cd backend && python -m mcp_servers.faq_search.server   → http://localhost:8010/mcp
#   cd backend && python -m mcp_servers.slack_notify.server → http://localhost:8011/mcp

# [백엔드 서비스에 설정] MCP 서버 연결 URL
# MCP_FAQ_URL=http://localhost:8010/mcp                            # 로컬
# MCP_FAQ_URL=https://faq-mcp-production-xxxx.up.railway.app/mcp  # Railway 배포 후 변경
# MCP_SLACK_URL=http://localhost:8011/mcp                             # 로컬
# MCP_SLACK_URL=https://slack-mcp-production-xxxx.up.railway.app/mcp # Railway 배포 후 변경

# [faq-mcp 서비스에 설정] FAQ MCP 서버 자체 설정
# OPENAI_API_KEY=sk-...          (위와 동일)
# FAQ_CHROMA_PATH=./chroma_db
# FAQ_COLLECTION_NAME=faq
# FAQ_DATA_DIR=./data
# FAQ_QUESTION_COL=FAQ_제목
# FAQ_ANSWER_COL=FAQ_내용

# [slack-mcp 서비스에 설정] Slack MCP 서버 자체 설정
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
